# ── Banco de dados ────────────────────────────────────────────────────────────
MONGO_PASSWORD=changeme                          # TROQUE por senha forte em prod
REDIS_URL=redis://redis:6379

# ── Autenticação ──────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-256-bit-string   # gere com: openssl rand -hex 32
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── IA ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=xploiter/the-xploiter:latest
OLLAMA_TIMEOUT=30                                # segundos

# ── HackerOne ────────────────────────────────────────────────────────────────
HACKERONE_USERNAME=your_h1_username
HACKERONE_API_USERNAME=your_h1_api_username
HACKERONE_API_TOKEN=your_h1_api_token

# ── Frontend ──────────────────────────────────────────────────────────────────
# Dev local:
NEXT_PUBLIC_API_URL=http://localhost:8000/api
# Produção (setup-ec2.sh substitui automaticamente):
# NEXT_PUBLIC_API_URL=https://SEU_DOMINIO/api

# ── Workers / Performance ─────────────────────────────────────────────────────
WEB_CONCURRENCY=2                                # uvicorn workers (ajuste ao nº de vCPUs)
MAX_JOBS=10                                      # max jobs ARQ simultâneos por worker
RATE_LIMIT_PER_MINUTE=120
ENABLE_CACHING=true

# ── Recon — APIs opcionais (ampliam descoberta de URLs/subdomínios) ───────────
# Sem estas keys o recon funciona normalmente; com elas, encontra muito mais
URLSCAN_API_KEY=                                 # urlscan.io — grátis em urlscan.io/user/signup
OTX_API_KEY=                                     # AlienVault OTX — grátis em otx.alienvault.com
SHODAN_API_KEY=                                  # Shodan — shodan.io (subfinder)
CENSYS_API_ID=                                   # Censys API ID — censys.io
CENSYS_API_SECRET=                               # Censys API Secret
CHAOS_API_KEY=                                   # ProjectDiscovery Chaos — chaos.projectdiscovery.io
VIRUSTOTAL_API_KEY=                              # VirusTotal — virustotal.com
SECURITYTRAILS_TOKEN=                            # SecurityTrails — securitytrails.com

# ── Asset Discovery — APIs para encontrar mais alvos ─────────────────────────
# github.com/settings/tokens → New token → scope: public_repo (read)
# Sem token: 10 req/min | Com token: 30 req/min
GITHUB_TOKEN=                                    # GitHub PAT — github_recon
